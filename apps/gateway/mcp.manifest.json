{
  "name": "afo-ask-copilot",
  "version": "0.2.0",
  "description": "Private single-user read-only Remote MCP gateway for AFO Ask Copilot.",
  "transport": {
    "type": "streamable_http",
    "path": "/mcp",
    "authentication": "bearer",
    "token_secret": "AFO_ASK_COPILOT_TOKEN"
  },
  "protocol_versions": [
    "2025-06-18",
    "2025-11-25"
  ],
  "limits": {
    "request_body_bytes": 256000,
    "prompt_characters": 20000
  },
  "tools": [
    {
      "name": "ask_copilot",
      "description": "Accept a read-only question for GitHub Copilot. In v0.2 the gateway returns an explicit placeholder and does not contact Copilot.",
      "inputSchema": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "prompt": {
            "type": "string",
            "minLength": 1,
            "maxLength": 20000,
            "description": "Question or task intended for Copilot."
          },
          "repository": {
            "type": "string",
            "minLength": 3,
            "maxLength": 200,
            "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$",
            "description": "Optional repository in owner/repo form."
          },
          "model": {
            "type": "string",
            "minLength": 1,
            "maxLength": 100,
            "description": "Optional future Copilot model identifier."
          },
          "session_id": {
            "type": "string",
            "minLength": 1,
            "maxLength": 200,
            "description": "Optional future resumable Copilot session identifier."
          }
        },
        "required": [
          "prompt"
        ]
      }
    }
  ],
  "runtime_execution": "placeholder_not_contacted",
  "mutation_tools_enabled": false
}
